# SESIS-FEDERATION — Environment Configuration
# -------------------------------------------------

# --- Backend ---
SECRET_KEY=change-this-to-a-random-64-char-string
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=DEBUG

# --- Database ---
DATABASE_URL=postgresql+asyncpg://sesis:sesis_password@postgres:5432/sesis
POSTGRES_USER=sesis
POSTGRES_PASSWORD=sesis_password
POSTGRES_DB=sesis

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- NATS (C2 Messaging) ---
NATS_URL=nats://nats:4222

# --- Neo4j (Link Analysis) ---
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# --- LLM (fsociety via Ollama) ---
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=fsociety
OLLAMA_TIMEOUT=120

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# --- CORS (comma-separated origins) ---
CORS_ORIGINS=http://localhost:3000,http://localhost:8501

# --- Security ---
FERNET_KEY_PATH=fernet.key
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
MFA_ENABLED=true

# --- Monitoring ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=
PROMETHEUS_RETENTION=15d
